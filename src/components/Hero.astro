---
import Icon from "./Icon.astro";
import { profile } from "../data/profile";
import { useTranslations, useCurrentLanguage } from "../i18n/utils";

const lang = useCurrentLanguage(Astro.currentLocale);
const t = useTranslations(lang);

// The two contacts that don't get their own button. WhatsApp is a CTA instead,
// and the location is the eyebrow — so nothing appears twice.
const contacts = [
  {
    icon: "mail",
    href: `mailto:${profile.email}`,
    label: t("hero.email"),
    value: profile.email,
  },
  {
    icon: "linkedin",
    href: profile.linkedin,
    label: "LinkedIn",
    value: profile.linkedinHandle,
  },
] as const;
---

<section
  class="flex min-h-[calc(100dvh-3.5rem)] w-full bg-[url('/lines-bg.svg')] bg-cover bg-center bg-no-repeat"
>
  <div
    class="m-auto grid w-full max-w-5xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:gap-14"
  >

    <div class="">
      <div class="relative mx-auto w-44 sm:w-56 md:w-full md:max-w-sm">
        <div
          class="absolute inset-0 translate-x-3 translate-y-3 rounded-3xl border border-primary/40"
          aria-hidden="true"
        >
        </div>
        <img
          src={profile.image}
          alt={t("hero.portraitAlt")}
          width="480"
          height="600"
          class="relative aspect-4/5 w-full rounded-3xl border border-foreground/10 bg-background object-cover"
        />
      </div>
    </div>
    
    <div class="flex flex-col items-start">
      <p
        class="inline-flex items-center gap-1.5 rounded-full border border-foreground/10 bg-background/60 px-3 py-1 text-xs text-foreground/60 backdrop-blur-sm"
      >
        <Icon name="pin" class="size-3.5" />
        {t("hero.location")}
      </p>

      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl">
        {t("hero.name")}
      </h1>
      <p class="mt-2 text-lg font-medium text-primary sm:text-xl">
        {t("hero.role")}
      </p>
      <p class="mt-5 max-w-md text-pretty text-foreground/70">
        {t("hero.description")}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={profile.cv}
          download
          class="inline-flex items-center gap-2 rounded-lg border-2 border-primary bg-primary px-5 py-2.5 text-sm font-medium text-background transition hover:border-secondary hover:bg-secondary"
        >
          <Icon name="download" class="size-4" />
          {t("hero.cv")}
        </a>
        <a
          href={`https://wa.me/${profile.phone}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-foreground/15 px-5 py-2.5 text-sm font-medium text-foreground/80 transition hover:border-foreground/30 hover:text-foreground"
        >
          <Icon name="whatsapp" class="size-4" />
          {t("hero.whatsapp")}
        </a>
      </div>

      <ul
        class="mt-8 flex w-full flex-wrap gap-x-6 gap-y-2 border-t border-foreground/10 pt-6 text-sm"
      >
        {
          contacts.map(({ icon, href, label, value }) => (
            <li>
              <a
                href={href}
                aria-label={label}
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="inline-flex items-center gap-2 text-foreground/60 transition hover:text-foreground"
              >
                <Icon name={icon} class="size-4" />
                {value}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
