---
import {useTranslations, useCurrentLanguage} from "../i18n/utils";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import Nav from "../components/Nav.astro";
import "../styles/global.css";

const lang = useCurrentLanguage(Astro.currentLocale);
const t = useTranslations(lang);
---


<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/damian-darkbg.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<Font cssVariable="--font-outfit" preload />
		<title>{t("meta.title")}</title>
		<ClientRouter />
	</head>
	<body transition:animate="fade" class="bg-background text-foreground">
		<Nav />
		<main class="flex flex-col justify-center items-center">
			<slot />
		</main>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
